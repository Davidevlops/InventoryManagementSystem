<!--  Views/ProductView.xaml  -->
<UserControl
    x:Class="InventoryManagementSystem.Views.ProductView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  Product List  -->
        <DataGrid
            Grid.Column="0"
            Margin="0,0,15,0"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            ItemsSource="{Binding Products}"
            SelectedItem="{Binding SelectedProduct}">

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="60"
                    Binding="{Binding Id}"
                    Header="ID" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Product Name" />
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding Price, StringFormat=C}"
                    Header="Price" />
                <DataGridTextColumn
                    Width="110"
                    Binding="{Binding StockQuantity}"
                    Header="Stock" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding ReorderLevel}"
                    Header="Reorder" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Supplier.Name}"
                    Header="Supplier" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Edit Form  -->
        <StackPanel
            Grid.Column="1"
            Width="340"
            Margin="10,0,0,0">

            <TextBlock
                Margin="0,0,0,15"
                FontSize="18"
                FontWeight="Bold"
                Text="Product Details" />

            <Label Content="Product Name" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Description" />
            <TextBox
                MinHeight="80"
                AcceptsReturn="True"
                IsEnabled="{Binding IsEditMode}"
                Text="{Binding Description}"
                TextWrapping="Wrap" />

            <Label Content="Price" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Stock Quantity" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding StockQuantity, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Reorder Level" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding ReorderLevel, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Supplier" />
            <ComboBox
                DisplayMemberPath="Name"
                IsEnabled="{Binding IsEditMode}"
                ItemsSource="{Binding Suppliers}"
                SelectedItem="{Binding SelectedSupplier}" />

            <!--  Buttons  -->
            <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Command="{Binding NewProductCommand}"
                    Content="New" />

                <Button
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Command="{Binding SaveProductCommand}"
                    Content="Save"
                    IsEnabled="{Binding IsEditMode}" />

                <Button
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Command="{Binding DeleteProductCommand}"
                    Content="Delete" />

                <Button
                    Padding="16,8"
                    Command="{Binding CancelEditCommand}"
                    Content="Cancel" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
