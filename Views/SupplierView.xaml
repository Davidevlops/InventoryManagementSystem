<!--  Views/SupplierView.xaml  -->
<UserControl
    x:Class="InventoryManagementSystem.Views.SupplierView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  Supplier List  -->
        <DataGrid
            Grid.Column="0"
            Margin="0,0,15,0"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            ItemsSource="{Binding Suppliers}"
            SelectedItem="{Binding SelectedSupplier}">

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="60"
                    Binding="{Binding Id}"
                    Header="ID" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding Name}"
                    Header="Name" />
                <DataGridTextColumn
                    Width="160"
                    Binding="{Binding ContactName}"
                    Header="Contact Name" />
                <DataGridTextColumn
                    Width="130"
                    Binding="{Binding Phone}"
                    Header="Phone" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding Email}"
                    Header="Email" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Products.Count}"
                    Header="Products" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Address}"
                    Header="Address" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Edit Form  -->
        <StackPanel
            Grid.Column="1"
            Width="320"
            Margin="10,0,0,0">

            <TextBlock
                Margin="0,0,0,15"
                FontSize="18"
                FontWeight="Bold"
                Text="Supplier Details" />

            <Label Content="Name" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Contact Name" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Phone Number" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Email" />
            <TextBox IsEnabled="{Binding IsEditMode}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="Address" />
            <TextBox
                MinHeight="80"
                AcceptsReturn="True"
                IsEnabled="{Binding IsEditMode}"
                Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" />

            <!--  Buttons  -->
            <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Command="{Binding NewSupplierCommand}"
                    Content="New" />

                <Button
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Command="{Binding SaveSupplierCommand}"
                    Content="Save"
                    IsEnabled="{Binding IsEditMode}" />

                <Button
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Command="{Binding DeleteSupplierCommand}"
                    Content="Delete" />

                <Button
                    Padding="16,8"
                    Command="{Binding CancelEditCommand}"
                    Content="Cancel" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
