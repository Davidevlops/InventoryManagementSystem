<Application
    x:Class="InventoryManagementSystem.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:InventoryManagementSystem.Helpers.Converters"
    xmlns:local="clr-namespace:InventoryManagementSystem"
    xmlns:views="clr-namespace:InventoryManagementSystem.Views"
    xmlns:vm="clr-namespace:InventoryManagementSystem.ViewModels">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:ProductViewModel}">
            <views:ProductView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SupplierViewModel}">
            <views:SupplierView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AlertViewModel}">
            <views:AlertView />
        </DataTemplate>
        <converters:CountToVisibilityConverter x:Key="ZeroToCollapsedConverter" />
    </Application.Resources>
</Application>
